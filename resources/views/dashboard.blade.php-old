    <script>
        // Initialize Lucide icons
        lucide.createIcons();
        
        // Revenue Chart
        const revenueOptions = {
            series: [{
                name: 'Revenue',
                data: @json($revenueData)
            }, {
                name: 'Collections',
                data: @json($collectionsData)
            }],
            chart: {
                type: 'area',
                height: 320,
                fontFamily: 'Inter, sans-serif',
                toolbar: { show: false },
                animations: {
                    enabled: true,
                    easing: 'easeinout',
                    speed: 800,
                    dynamicAnimation: { enabled: true, speed: 500 }
                }
            },
            colors: ['#4F46E5', '#10B981'],
            fill: {
                type: 'gradient',
                gradient: {
                    shadeIntensity: 1,
                    opacityFrom: 0.4,
                    opacityTo: 0.05,
                    stops: [0, 90, 100]
                }
            },
            dataLabels: { enabled: false },
            stroke: { curve: 'smooth', width: [2, 2] },
            xaxis: {
                categories: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'],
                axisBorder: { show: false },
                axisTicks: { show: false },
                labels: { style: { colors: '#94a3b8', fontSize: '12px' } }
            },
            yaxis: {
                labels: {
                    style: { colors: '#94a3b8', fontSize: '12px' },
                    formatter: (value) => '₹' + value + 'L'
                }
            },
            grid: {
                borderColor: '#f1f5f9',
                strokeDashArray: 4,
                xaxis: { lines: { show: false } }
            },
            legend: {
                position: 'top',
                horizontalAlign: 'right',
                fontSize: '12px',
                fontFamily: 'Inter, sans-serif',
                markers: { radius: 4 }
            },
            tooltip: {
                theme: 'light',
                x: { show: true },
                y: {
                    formatter: (value) => '₹' + value + 'L'
                }
            }
        };
        
        const revenueChart = new ApexCharts(document.querySelector("#revenueChart"), revenueOptions);
        revenueChart.render();
        
        // Funnel Chart
        const funnelOptions = {
            series: [{
                data: [{
                    x: 'Available',
                    y: {{ $donutAvailable }},
                }, {
                    x: 'Booked',
                    y: {{ $donutSold }},
                }, {
                    x: 'Reserved',
                    y: {{ $donutReserved }},
                }]
            }],
            chart: {
                type: 'bar',
                height: 160,
                fontFamily: 'Inter, sans-serif',
                toolbar: { show: false }
            },
            plotOptions: {
                bar: {
                    borderRadius: 4,
                    barHeight: '80%',
                    distributed: true,
                }
            },
            colors: ['#34D399', '#6366F1', '#F59E0B'],
            dataLabels: { enabled: false },
            legend: { show: false },
            xaxis: {
                labels: { style: { fontSize: '10px', colors: '#64748b' } },
                axisBorder: { show: false },
                axisTicks: { show: false }
            },
            yaxis: { show: false },
            grid: { show: false }
        };
        
        const funnelChart = new ApexCharts(document.querySelector("#funnelChart"), funnelOptions);
        funnelChart.render();
        
        // Mini charts using Canvas
        function drawMiniChart(canvasId, data, color) {
            const canvas = document.getElementById(canvasId);
            if (!canvas) return;
            
            const ctx = canvas.getContext('2d');
            canvas.width = canvas.offsetWidth;
            canvas.height = canvas.offsetHeight;
            
            const max = Math.max(...data);
            const min = Math.min(...data);
            const range = max - min || 1;
            
            ctx.strokeStyle = color;
            ctx.lineWidth = 2;
            ctx.lineCap = 'round';
            ctx.lineJoin = 'round';
            
            const step = canvas.width / (data.length - 1);
            
            ctx.beginPath();
            data.forEach((value, index) => {
                const x = index * step;
                const y = canvas.height - ((value - min) / range) * (canvas.height - 8) - 4;
                if (index === 0) {
                    ctx.moveTo(x, y);
                } else {
                    ctx.lineTo(x, y);
                }
            });
            ctx.stroke();
        }
        
        // Draw mini charts after page load
        window.addEventListener('load', () => {
            drawMiniChart('cashFlowChart', [30, 45, 35, 50, 40, 55, 42, 58, 48, 52, 45, 50], '#4F46E5');
            drawMiniChart('expensesChart', [40, 35, 45, 30, 38, 42, 35, 40, 38, 42, 40, 38], '#F59E0B');
            drawMiniChart('receivablesChart', [20, 25, 30, 28, 35, 32, 38, 35, 40, 38, 42, 40], '#3B82F6');
        });
    </script>
    
